# Environment variables for local development
FLASK_APP=autoapp.py
FLASK_DEBUG=1
FLASK_ENV=development
GUNICORN_WORKERS=1
LOG_LEVEL=debug
LOG_CONTEXT=off
LOG_COMPLETION=on
RECORD_TRAFFIC=off

# Arbitrary API key to protect your service.
SERVICE_API_KEY=change-me

# Provider switches. Root and /azure use Azure; /codex uses Codex.
ENABLE_AZURE=true
ENABLE_CODEX=false

# Mandatory Azure settings
AZURE_BASE_URL=https://change-me.openai.azure.com
AZURE_API_KEY=change-me

# Optional JSON mapping from Cursor-facing model ids to Azure deployment names.
# Leave empty to use matching deployment names for all supported models.
# Example:
# AZURE_MODEL_DEPLOYMENTS={"gpt-5.4":"my-prod-gpt54","gpt-5.4-mini":"team-mini"}
AZURE_MODEL_DEPLOYMENTS=

# Optional Azure settings
AZURE_SUMMARY_LEVEL=
AZURE_VERBOSITY_LEVEL=
AZURE_TRUNCATION=

# Optional Codex provider settings. Enable Codex only after `codex login`.
CODEX_AUTH_PATH=~/.codex/auth.json
CODEX_RESPONSES_URL=https://chatgpt.com/backend-api/codex/responses
CODEX_SUPPORTED_MODELS=gpt-5.5,gpt-5.4,gpt-5.4-mini,gpt-5.3-codex,gpt-5.3-codex-spark
CODEX_MODEL_REWRITES=
CODEX_ORIGINATOR=codex_cli_rs
CODEX_USER_AGENT="codex_cli_rs/0.130.0 cursor-provider-proxy/0.1"
# Set true if Cursor omits conversation markers on some requests (see README Troubleshooting).
CODEX_DISCOVERY_MODE=false
CODEX_TOKEN_REFRESH_SKEW_SECONDS=300
CODEX_REQUEST_TIMEOUT_SECONDS=600
